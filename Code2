	HITBOX  = Color3.fromRGB(255, 50,  50),
	LOS     = Color3.fromRGB(0,   255, 80),
	STEER   = Color3.fromRGB(255, 200, 0),
	PATH    = Color3.fromRGB(0,   150, 255),
