local function loadAnim(id)
	local anim = Instance.new("Animation")
	anim.AnimationId = "rbxassetid://" .. id
	return animator:LoadAnimation(anim)
end

local trackIdle   = loadAnim(CFG.ANIM_IDLE)
local trackWalk   = loadAnim(CFG.ANIM_WALK)
local trackAttack = loadAnim(CFG.ANIM_ATTACK)
trackAttack.Priority = Enum.AnimationPriority.Action

local function setMoveAnim(track)
	if track == trackIdle then
		if not trackIdle.IsPlaying then trackWalk:Stop(0.1); trackIdle:Play(0.1) end
	elseif track == trackWalk then
		if not trackWalk.IsPlaying then trackIdle:Stop(0.1); trackWalk:Play(0.1) end
	end
end

