local debugFolder = Instance.new("Folder")
debugFolder.Name   = "SkarDebug"
debugFolder.Parent = workspace

local stateLabel = nil

local function dbg_sphere(pos, radius, color, lifetime)
	if not DEBUG_MODE then return end
	local p = Instance.new("Part")
	p.Shape = Enum.PartType.Ball
	p.Size  = Vector3.new(radius*2, radius*2, radius*2)
	p.CFrame = CFrame.new(pos); p.Anchored = true
	p.CanCollide = false; p.CanQuery = false
	p.Material = Enum.Material.Neon; p.Color = color
	p.Transparency = 0.5; p.CastShadow = false
	p.Parent = debugFolder
	if lifetime then Debris:AddItem(p, lifetime) end
end

local function dbg_ray(origin, dir, color, lifetime)
	if not DEBUG_MODE then return end
	local len = dir.Magnitude
	if len < 0.1 then return end
	local mid = origin + dir * 0.5
	local p = Instance.new("Part")
	p.Size = Vector3.new(0.1, 0.1, len)
	p.CFrame = CFrame.lookAt(mid, origin + dir)
	p.Anchored = true; p.CanCollide = false; p.CanQuery = false
	p.Material = Enum.Material.Neon; p.Color = color
	p.Transparency = 0.3; p.CastShadow = false
	p.Parent = debugFolder
	if lifetime then Debris:AddItem(p, lifetime) end
end

local function dbg_setState(text, color)
	if not DEBUG_MODE or not stateLabel then return end
	stateLabel.Text       = text
	stateLabel.TextColor3 = color or Color3.fromRGB(255, 255, 255)
end

