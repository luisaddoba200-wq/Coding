local navParams = RaycastParams.new()
navParams.FilterDescendantsInstances = {killer}
navParams.FilterType = Enum.RaycastFilterType.Exclude

local currentTarget    = nil
local currentTargetHRP = nil

local function updateTarget()
	local nearest, minDist = nil, math.huge
	for _, p in Players:GetPlayers() do
		local char = p.Character
		if char and char:FindFirstChild("Humanoid") and char.Humanoid.Health > 0
			and char:FindFirstChild("HumanoidRootPart") then
			local dist = (char.HumanoidRootPart.Position - hrp.Position).Magnitude
			if dist < minDist then minDist = dist; nearest = char end
		end
	end
	currentTarget    = nearest
	currentTargetHRP = nearest and nearest:FindFirstChild("HumanoidRootPart") or nil
	return nearest, minDist
end

local function getTargetPos()
	if not currentTargetHRP or not currentTargetHRP.Parent then return nil end
	return currentTargetHRP.Position
end

local function hasLOS(from, to)
	local origin = from + Vector3.new(0, 1.5, 0)
	local dir    = (to  + Vector3.new(0, 1.0, 0)) - origin
	local result = workspace:Raycast(origin, dir, navParams)
	return not result or result.Distance >= dir.Magnitude * 0.92
end

local function hasDangerousDrop(pos)
	local hit = workspace:Raycast(
		pos + Vector3.new(0, 3, 0),
		Vector3.new(0, -(CFG.FALL_DANGER_H + 3), 0),
		navParams
	)
	return not hit
end

