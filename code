local function breakObstacles()
	local forward = hrp.CFrame.LookVector
	local dirs    = {forward*5, (CFrame.Angles(0,math.rad(28),0)*forward)*5, (CFrame.Angles(0,math.rad(-28),0)*forward)*5}
	local params  = RaycastParams.new()
	params.FilterDescendantsInstances = {killer}
	params.FilterType = Enum.RaycastFilterType.Exclude

	for _, dir in ipairs(dirs) do
		local hit = workspace:Raycast(hrp.Position, dir, params)
		if hit and hit.Instance then
			local inst = hit.Instance
			if inst:GetAttribute("Breakable") or CollectionService:HasTag(inst,"Breakable")
				or inst.Name == "Door" or inst.Name == "Glass" or inst.Name == "Breakable" then
				local mdl = inst:FindFirstAncestorOfClass("Model")
				local h   = mdl and mdl:FindFirstChildOfClass("Humanoid")
				if h then h:TakeDamage(9999) else inst:Destroy() end
				sfx(CFG.SFX.BREAK, 0.9, 1.1)
				break
			end
		end
	end
end

