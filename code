local function applyKnockback(tHRP, direction, force)
	if not tHRP or not tHRP.Parent then return end
	local att = tHRP:FindFirstChildOfClass("Attachment") or Instance.new("Attachment", tHRP)
	local lv  = Instance.new("LinearVelocity", tHRP)
	lv.Attachment0    = att
	lv.VectorVelocity = direction.Unit * force
	lv.MaxForce       = 6e5
	Debris:AddItem(lv, 0.14)
end

local function areaHit(damage, radius, offsetZ, alreadyHit)
	local center = (hrp.CFrame * CFrame.new(0, 0, -(offsetZ or 4))).Position
	local params = OverlapParams.new()
	params.FilterDescendantsInstances = {killer}
	params.FilterType = Enum.RaycastFilterType.Exclude
	alreadyHit = alreadyHit or {}

	for _, part in workspace:GetPartBoundsInRadius(center, radius or 6, params) do
		local model = part:FindFirstAncestorOfClass("Model")
		if model and model ~= killer and not alreadyHit[model] then
			local hum  = model:FindFirstChildOfClass("Humanoid")
			local tHRP = model:FindFirstChild("HumanoidRootPart")
			if hum and hum.Health > 0 then
				alreadyHit[model] = true
				local mult = ai.rageActive and CFG.RAGE_DMG_MULT or 1
				hum:TakeDamage(math.floor(damage * mult))
				if tHRP then
					applyKnockback(tHRP, tHRP.Position - hrp.Position + Vector3.new(0,0.5,0), CFG.KNOCKBACK_FORCE)
				end
			end
		end
	end
	return alreadyHit
end

