-- ✅ FIX PRINCIPAL DEL CONGELADO:
-- Antes: trackAttack.Stopped:Wait() podía esperar para siempre
-- Ahora: timeout de seguridad garantiza que isAttacking vuelva a false
local function doAttack()
	if isAttacking then return end
	local now = tick()
	if now - lastAttackTime < CFG.ATTACK_COOLDOWN then return end

	isAttacking    = true
	lastAttackTime = now
	humanoid:MoveTo(hrp.Position)
	trackIdle:Stop(0.05); trackWalk:Stop(0.05)
	trackAttack:Play(0.05)

	-- Esperar a que termine con timeout de seguridad
	local waitStart = tick()
	local done = false

	-- Conexión a Stopped
	local conn = trackAttack.Stopped:Connect(function()
		done = true
	end)

	-- Esperar con timeout
	while not done and (tick() - waitStart) < CFG.ATTACK_MAX_TIME do
		task.wait(0.05)
	end

	conn:Disconnect()

	-- Limpiar estado sin importar si terminó o se colgó
	if trackAttack.IsPlaying then trackAttack:Stop(0.1) end
	isAttacking = false
end

