local function runLOS(getDestFn, activeFlag)
	dbg_setState("👁️ LOS", CLR.LOS)
	while activeFlag() do
		task.wait(CFG.LOS_RATE)
		if not activeFlag() or isAttacking then break end

		local dest = getDestFn()
		if not dest then break end

		if (hrp.Position - dest).Magnitude < CFG.ATTACK_RANGE then break end
		if not hasLOS(hrp.Position, dest) then break end
		if hasDangerousDrop(dest) then break end

		face(dest)
		humanoid:MoveTo(dest)
		if dest.Y > hrp.Position.Y + 2.5 then humanoid.Jump = true end
	end
end

-- ============================================================
-- 🔀 CAPA 2: RAYCAST STEERING MEJORADO
-- ✅ NUEVO: además de rayos horizontales, detecta escaleras y
-- superficies pisables en altura con rayos diagonales.
-- ============================================================

-- Precalcular ángulos de steering
local STEER_ANGLES = {}
for i = 0, CFG.STEER_RAYS - 1 do
	STEER_ANGLES[i + 1] = (i / CFG.STEER_RAYS) * math.pi * 2
end

-- ✅ NUEVO: Detecta si hay una superficie pisable (escalera/rampa/plataforma)
-- en una dirección horizontal dada, hasta cierta altura.
-- Devuelve la Y del suelo encontrado, o nil si no hay.
local function detectStairInDir(dir, targetHeight)
	-- Lanzar rayo diagonal: desde la posición del killer + altura,
	-- hacia adelante-abajo para encontrar el suelo de la escalera
	local checkHeights = {2.0, 3.5, CFG.STAIR_CHECK_H}  -- probar a varias alturas

	for _, h in ipairs(checkHeights) do
		-- Solo nos interesa si el target está más arriba que nosotros
		if targetHeight - hrp.Position.Y < 1.5 then break end

		local startPos = hrp.Position + Vector3.new(0, h, 0)
		local checkPos = startPos + dir * CFG.STAIR_CHECK_DIST

		-- Rayo hacia abajo desde el punto de check
		local groundHit = workspace:Raycast(
			checkPos + Vector3.new(0, 2, 0),
			Vector3.new(0, -(CFG.STAIR_VDIST + 2), 0),
			navParams
		)

		if groundHit then
			local floorY = groundHit.Position.Y
			-- Es una subida válida si el suelo encontrado está más alto que donde estamos
			if floorY > hrp.Position.Y + 0.3 then
				if DEBUG_MODE then
					dbg_sphere(groundHit.Position, 0.4, CLR.STAIR, 0.1)
				end
				return floorY
			end
		end
	end
	return nil
end

local function getBestSteerDir(targetPos)
	local toTarget   = targetPos - hrp.Position
	local flatTarget = Vector3.new(toTarget.X, 0, toTarget.Z)
	if flatTarget.Magnitude < 0.1 then return nil end
	local desired    = flatTarget.Unit
	local heightDiff = targetPos.Y - hrp.Position.Y  -- ¿target está arriba o abajo?

	local bestDir   = nil
	local bestScore = -math.huge

	for _, angle in ipairs(STEER_ANGLES) do
		local testDir = Vector3.new(math.cos(angle), 0, math.sin(angle))

		-- ── Rayo horizontal de obstáculo ─────────────────────
		local rayOrigin = hrp.Position + Vector3.new(0, 1, 0)
		local hit = workspace:Raycast(rayOrigin, testDir * CFG.STEER_DIST, navParams)

		local clearDist = hit and hit.Distance or CFG.STEER_DIST
		local isFree    = clearDist > CFG.STEER_DIST * 0.55

		if isFree then
			-- Score base: alineación con el target
			local alignment  = testDir:Dot(desired)
			local openBonus  = (clearDist / CFG.STEER_DIST) * 0.5

			-- ✅ NUEVO: bonus de escalera/subida
			-- Si el target está arriba y esta dirección tiene superficie pisable
			-- a mayor altura, se le da un bonus fuerte
			local stairBonus = 0
			if heightDiff > 2.0 then
				local stairY = detectStairInDir(testDir, targetPos.Y)
				if stairY then
					-- Bonus proporcional a qué tanto sube
					local gain = math.clamp((stairY - hrp.Position.Y) / CFG.STAIR_CHECK_H, 0, 1)
					stairBonus = gain * CFG.STAIR_BONUS

					if DEBUG_MODE then
						dbg_ray(
							hrp.Position + Vector3.new(0, 1, 0),
							testDir * CFG.STAIR_CHECK_DIST,
							CLR.STAIR, 0.1
						)
					end
				end
			end

			local score = alignment + openBonus + stairBonus

			if DEBUG_MODE then
				local rayColor = stairBonus > 0 and CLR.STAIR
					or (alignment > 0.4 and CLR.STEER or Color3.fromRGB(80, 80, 80))
				dbg_ray(rayOrigin, testDir * clearDist, rayColor, 0.06)
			end

			if score > bestScore then
				bestScore = score
				bestDir   = testDir
			end
		end
	end

	return bestDir, bestScore
end

local function runSteering(getDestFn, activeFlag)
	dbg_setState("🔀 STEERING", CLR.STEER)

	local stuckRef   = hrp.Position
	local stuckTimer = 0
	local pfThread   = nil
	local pfActive   = false

	local function startBackupPF(dest)
		if pfActive then return end
		pfActive = true
		dbg_setState("🧭 PF RESPALDO", CLR.PATH)

		pfThread = task.spawn(function()
			local path = PathfindingService:CreatePath(CFG.AGENT_PARAMS)
			local ok   = pcall(function() path:ComputeAsync(hrp.Position, dest) end)
			if not ok or path.Status ~= Enum.PathStatus.Success then
				pfActive = false; return
			end

			local wps = path:GetWaypoints()
			for i = 2, #wps do
				if not activeFlag() or not pfActive then break end
				local wp = wps[i]

				if i < #wps and hasLOS(hrp.Position, wps[i+1].Position) then continue end
				if hasDangerousDrop(wp.Position) then pfActive = false; break end

				if wp.Action == Enum.PathWaypointAction.Jump
					or (wp.Position.Y - hrp.Position.Y) > 0.8 then
					if humanoid.FloorMaterial ~= Enum.Material.Air then
						humanoid.Jump = true; task.wait(0.1)
					end
				end

				face(wp.Position)
				humanoid:MoveTo(wp.Position)

				local elapsed = 0
				while elapsed < CFG.PF_TIMEOUT and activeFlag() and pfActive do
					task.wait(0.05); elapsed += 0.05
					if (hrp.Position - wp.Position).Magnitude < CFG.PF_WAYPOINT_DIST then break end
					local tPos = getDestFn()
					if tPos and hasLOS(hrp.Position, tPos) then pfActive = false; break end
				end
				if not pfActive then break end
			end
			pfActive = false
		end)
	end

	local function stopBackupPF()
		pfActive = false
		if pfThread then pcall(function() task.cancel(pfThread) end); pfThread = nil end
	end

	while activeFlag() do
		task.wait(CFG.STEER_RATE)
		if not activeFlag() or isAttacking then break end

		local dest = getDestFn()
		if not dest then break end

		if (hrp.Position - dest).Magnitude < CFG.ATTACK_RANGE then break end
		if hasLOS(hrp.Position, dest) then stopBackupPF(); break end

		local steerDir, steerScore = getBestSteerDir(dest)

		if steerDir then
			stopBackupPF()

			local moveTarget = hrp.Position + steerDir * CFG.STEER_REACH

			-- Snap al suelo del punto de destino
			local groundHit = workspace:Raycast(
				moveTarget + Vector3.new(0, CFG.STAIR_CHECK_H + 2, 0),
				Vector3.new(0, -(CFG.STAIR_CHECK_H + CFG.STAIR_VDIST + 2), 0),
				navParams
			)
			if groundHit then
				local floorY = groundHit.Position.Y + 0.5
				moveTarget = Vector3.new(moveTarget.X, floorY, moveTarget.Z)
			end

			-- ✅ Saltar si el punto de destino está más alto (escalera o rampa)
			if moveTarget.Y > hrp.Position.Y + 0.6 then
				if humanoid.FloorMaterial ~= Enum.Material.Air == false then
					humanoid.Jump = true
				end
			end

			-- Salto si el target está arriba y estamos en el suelo
			if dest.Y > hrp.Position.Y + 3.0
				and humanoid.FloorMaterial ~= Enum.Material.Air then
				humanoid.Jump = true
			end

			face(dest)
			humanoid:MoveTo(moveTarget)
		else
			if not pfActive then startBackupPF(dest) end
		end

		-- Stuck detection
		stuckTimer += CFG.STEER_RATE
		if stuckTimer >= CFG.PF_TRIGGER_TIME then
			local moved = (hrp.Position - stuckRef).Magnitude
			if moved < CFG.PF_STUCK_DIST then
				if not pfActive then
					startBackupPF(dest)
				else
					humanoid.Jump = true
				end
			end
			stuckTimer = 0
			stuckRef   = hrp.Position
		end
	end

	stopBackupPF()
end

