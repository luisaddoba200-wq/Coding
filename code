local tracks = {}
for name, id in pairs(CFG.ANIM) do
	local anim = Instance.new("Animation")
	anim.AnimationId = "rbxassetid://" .. id
	local t = animator:LoadAnimation(anim)
	if name == "ATTACK" or name == "WAVE" then
		t.Priority = Enum.AnimationPriority.Action
	end
	tracks[name] = t
end

local function playAnim(name, fade)
	local t = tracks[name]
	if t and not t.IsPlaying then t:Play(fade or 0.15) end
end
local function stopAnim(name, fade)
	local t = tracks[name]
	if t and t.IsPlaying then t:Stop(fade or 0.15) end
end
local function stopMoveAnims()
	stopAnim("IDLE", 0.08); stopAnim("WALK", 0.08); stopAnim("RUN", 0.08)
end

