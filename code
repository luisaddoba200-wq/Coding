		local now = tick()
		local s   = ai.state

		if s == STATE.EXPLORE then
			humanoid.WalkSpeed = CFG.PATROL_SPEED
			if not ai.exploreTarget or (hrp.Position - ai.exploreTarget).Magnitude < 5 then
				local angle = math.random() * math.pi * 2
				local r     = 30 + math.random() * 30
				ai.exploreTarget = hrp.Position + Vector3.new(math.cos(angle)*r, 0, math.sin(angle)*r)
				cancelPath()
				face(ai.exploreTarget)
			end
			if ai.exploreTarget then navigateTo(ai.exploreTarget, now) end

		elseif s == STATE.CHASE then
			if not ai.target or not ai.target:FindFirstChild("HumanoidRootPart")
				or ai.target.Humanoid.Health <= 0 then
				ai.state = STATE.EXPLORE; ai.target = nil; cancelPath()
			else
				humanoid.WalkSpeed = CFG.CHASE_SPEED
				local tHRP = ai.target.HumanoidRootPart
				local dist = (tHRP.Position - hrp.Position).Magnitude
				face(tHRP.Position)

				if dist <= CFG.ATTACK_RANGE then
					cancelPath(); ai.state = STATE.ATTACK

					-- Trampa tiene prioridad si el jugador está cerca y el cooldown está listo
				elseif dist <= CFG.TRAP_RANGE and now - ai.lastTrapTime > CFG.COOLDOWN_TRAP then
					cancelPath(); ai.state = STATE.TRAP

				elseif dist >= CFG.WAVE_RANGE_MIN and dist <= CFG.WAVE_RANGE_MAX
					and now - ai.lastWaveTime > CFG.COOLDOWN_WAVE then
					cancelPath(); ai.state = STATE.WAVE

				else
					navigateTo(tHRP.Position, now)
					if tHRP.Position.Y > hrp.Position.Y + 2.8 then humanoid.Jump = true end
				end
			end

		elseif s == STATE.ATTACK then
			if not ai.target or not ai.target:FindFirstChild("HumanoidRootPart")
				or ai.target.Humanoid.Health <= 0 then
				ai.state = STATE.EXPLORE; ai.target = nil
			else
				local tHRP = ai.target.HumanoidRootPart
				local dist = (tHRP.Position - hrp.Position).Magnitude
				face(tHRP.Position)
				if dist > CFG.ATTACK_RANGE * 1.6 then
					ai.state = STATE.CHASE; ai.lastPathComputeTime = 0
				elseif not ai.isAttacking and now - ai.lastNormalTime > CFG.COOLDOWN_NORMAL then
					humanoid:MoveTo(dist > CFG.ATTACK_RANGE * 0.8 and tHRP.Position or hrp.Position)
					task.spawn(normalAttack)
				end
			end

		elseif s == STATE.WAVE then
			if not ai.target or not ai.target:FindFirstChild("HumanoidRootPart")
				or ai.target.Humanoid.Health <= 0 then
				ai.state = STATE.EXPLORE; ai.target = nil
			elseif not ai.isWaving then
				local tHRP = ai.target.HumanoidRootPart
				task.spawn(function() waveAttack(tHRP.Position); ai.state = STATE.CHASE end)
			end

		elseif s == STATE.TRAP then
			if not ai.target or not ai.target:FindFirstChild("HumanoidRootPart")
				or ai.target.Humanoid.Health <= 0 then
				ai.state = STATE.EXPLORE; ai.target = nil
			elseif not ai.isWaving then
				local tHRP = ai.target.HumanoidRootPart
				task.spawn(function() trapAttack(tHRP.Position); ai.state = STATE.CHASE end)
			end
		end
	end
end)

