-- ============================================================
local function getBestTarget()
	local best, bestDist = nil, math.huge
	for _, p in Players:GetPlayers() do
		local char = p.Character
		if char and char:FindFirstChild("Humanoid") and char.Humanoid.Health > 0
			and char:FindFirstChild("HumanoidRootPart") then
			local dist = (char.HumanoidRootPart.Position - hrp.Position).Magnitude
			if dist < bestDist then bestDist = dist; best = char end
		end
	end
	return best
end

-- ============================================================
--  💥 KNOCKBACK
-- ============================================================
local function applyKnockback(tHRP, direction, force)
	if not tHRP or not tHRP.Parent then return end
	local att = Instance.new("Attachment", tHRP)
	local lv  = Instance.new("LinearVelocity", tHRP)
	lv.Attachment0    = att
	lv.VectorVelocity = direction.Unit * force
	lv.MaxForce       = 6e5
	Debris:AddItem(lv,  0.14)
	Debris:AddItem(att, 0.14)
end

-- ============================================================
--  ⚔️ ATAQUE MELEE
--  Hitbox: GetPartBoundsInBox centrada adelante del killer
-- ============================================================
local function normalAttack()
	if ai.isAttacking then return end
	ai.isAttacking = true
	humanoid:MoveTo(hrp.Position)
	stopMoveAnims()
	tracks.ATTACK:Play(0.05)

	local fired = false
	local function doHit()
		if fired then return end; fired = true
		local hitCF   = hrp.CFrame * CFrame.new(0, 0, -4)
		local hitSize = Vector3.new(8, 6, 9)
		local params  = OverlapParams.new()
		params.FilterDescendantsInstances = {killer}
		params.FilterType = Enum.RaycastFilterType.Exclude

		for _, part in workspace:GetPartBoundsInBox(hitCF, hitSize, params) do
			local model = part:FindFirstAncestorOfClass("Model")
			if model and model ~= killer then
				local hum  = model:FindFirstChildOfClass("Humanoid")
				local tHRP = model:FindFirstChild("HumanoidRootPart")
				if hum and hum.Health > 0 then
					hum:TakeDamage(CFG.DAMAGE_NORMAL)
					sfx(CFG.SFX.HIT, 0.9, 0.85)
					if tHRP then
						applyKnockback(tHRP, tHRP.Position - hrp.Position + Vector3.new(0,0.4,0), CFG.KNOCKBACK_FORCE)
					end
				end
			end
		end
	end

	local conn = tracks.ATTACK:GetMarkerReachedSignal("NormalAttack"):Connect(doHit)
	task.delay(0.5, doHit)
	tracks.ATTACK.Stopped:Wait()
	conn:Disconnect()
	ai.isAttacking    = false
	ai.lastNormalTime = tick()
end

local ServerStorage = game:GetService("ServerStorage")

-- ============================================================
--  🌊 PROYECTIL — clona la Union de ServerStorage
--  Hitbox: GetPartBoundsInBox que sigue el CFrame del Part en movimiento
-- ============================================================
local function spawnProjectile(startCF, direction, speed, size, damage, lifetime)
	-- ✅ Clona tu Union roja de ServerStorage
	local waveTemplate = ServerStorage:FindFirstChild("ConstructWaver")
	if not waveTemplate then
		warn("[TheConstructor01] No se encontró 'ConstructWaver' en ServerStorage")
		return
	end

	local wave = waveTemplate:Clone()
	wave.CanCollide = false
	wave.Anchored   = false
	wave.CastShadow = false
	wave.CFrame     = startCF
	wave.Parent     = workspace
	Debris:AddItem(wave, lifetime)

	local att = Instance.new("Attachment", wave)
	local lv  = Instance.new("LinearVelocity", wave)
	lv.Attachment0    = att
	lv.VectorVelocity = direction * speed
	lv.MaxForce       = math.huge

	-- ✅ HITBOX: GetPartBoundsInBox sigue el Part cada frame
	local alreadyHit = {}
	local conn
	conn = RunService.Heartbeat:Connect(function()
		if not wave or not wave.Parent then conn:Disconnect(); return end

		local params = OverlapParams.new()
		params.FilterDescendantsInstances = {killer, wave}
		params.FilterType = Enum.RaycastFilterType.Exclude

		for _, part in workspace:GetPartBoundsInBox(wave.CFrame, wave.Size * 1.3, params) do
			local model = part:FindFirstAncestorOfClass("Model")
			if model and model ~= killer and not alreadyHit[model] then
				local hum  = model:FindFirstChildOfClass("Humanoid")
				local tHRP = model:FindFirstChild("HumanoidRootPart")
				if hum and hum.Health > 0 then
					alreadyHit[model] = true
					hum:TakeDamage(damage)
					sfx(CFG.SFX.WAVE_HIT, 1.0, 0.75)
					if tHRP then
						applyKnockback(tHRP, direction + Vector3.new(0, 0.3, 0), 55)
					end
				end
			end
		end
	end)

	task.delay(lifetime, function()
		conn:Disconnect()
		if wave and wave.Parent then wave:Destroy() end
	end)
end

-- ============================================================
--  🌊 ONDA NORMAL — Shockwave: partes que se spawnean en el suelo una tras otra
--  Atraviesa paredes, se detiene al golpear jugador o al llegar al límite
-- ============================================================
local function waveAttack(targetPos)
	if ai.isWaving or ai.isAttacking then return end
	ai.isWaving = true
	humanoid:MoveTo(hrp.Position)
	face(targetPos)
	stopMoveAnims()
	tracks.WAVE:Play(0.05)

	local fired = false
	local function doWave()
		if fired then return end; fired = true
		sfx(CFG.SFX.WAVE_LAUNCH, 1.2, 0.7)

		local dir = (Vector3.new(targetPos.X, hrp.Position.Y, targetPos.Z) - hrp.Position)
		dir = dir.Magnitude > 0.1 and dir.Unit or hrp.CFrame.LookVector

		local waveTemplate = ServerStorage:FindFirstChild("ConstructWaver")
		if not waveTemplate then warn("[TheConstructor01] No se encontró 'ConstructWaver' en ServerStorage"); return end

		local stepDist   = 3    -- studs entre cada parte
		local maxSteps   = math.floor(CFG.WAVE_RANGE_MAX / stepDist)
		local stepDelay  = 0.04 -- segundos entre cada parte (más rápido = más continuo)
		local partLife   = 0.35 -- cuánto dura visible cada parte
		local stopped    = false
		local alreadyHit = {}

		task.spawn(function()
			for i = 1, maxSteps do
				if stopped then break end

				local spawnPos = hrp.Position + dir * (i * stepDist)

				-- Raycast hacia abajo para poner la parte en el suelo
				local rayParams = RaycastParams.new()
				rayParams.FilterDescendantsInstances = {killer}
				rayParams.FilterType = Enum.RaycastFilterType.Exclude
				local groundHit = workspace:Raycast(spawnPos + Vector3.new(0, 5, 0), Vector3.new(0, -15, 0), rayParams)
				local groundY = groundHit and groundHit.Position.Y or spawnPos.Y

				-- Clonar la parte en esa posición
				local wave = waveTemplate:Clone()
				wave.CanCollide = false
				wave.Anchored   = true  -- ✅ Anclada, no se mueve — solo aparece y desaparece
				wave.CastShadow = false
				wave.CFrame     = CFrame.lookAt(
					Vector3.new(spawnPos.X, groundY + (waveTemplate.Size.Y / 2), spawnPos.Z),
					Vector3.new(spawnPos.X + dir.X, groundY + (waveTemplate.Size.Y / 2), spawnPos.Z + dir.Z)
				)
				wave.Parent = workspace
				Debris:AddItem(wave, partLife)

				-- ✅ Hitbox sobre esta parte
				local params = OverlapParams.new()
				params.FilterDescendantsInstances = {killer, wave}
				params.FilterType = Enum.RaycastFilterType.Exclude

				for _, part in workspace:GetPartBoundsInBox(wave.CFrame, wave.Size * 1.2, params) do
					local model = part:FindFirstAncestorOfClass("Model")
					if model and model ~= killer and not alreadyHit[model] then
						local hum  = model:FindFirstChildOfClass("Humanoid")
						local tHRP = model:FindFirstChild("HumanoidRootPart")
						if hum and hum.Health > 0 then
							alreadyHit[model] = true
							hum:TakeDamage(CFG.WAVE_DAMAGE)
							sfx(CFG.SFX.WAVE_HIT, 1.0, 0.75)
							-- ✅ Lanza al jugador hacia arriba
							if tHRP then
								applyKnockback(tHRP, Vector3.new(dir.X * 0.2, 1, dir.Z * 0.2), 85)
							end
							stopped = true
							break
						end
					end
				end

				task.wait(stepDelay)
			end
		end)
	end

	local conn = tracks.WAVE:GetMarkerReachedSignal("ONDADEATAQUE!"):Connect(doWave)
	task.delay(0.6, doWave)
	tracks.WAVE.Stopped:Wait()
	conn:Disconnect()
	ai.isWaving     = false
	ai.lastWaveTime = tick()
end

-- ============================================================
--  🧱 ONDA TRAMPA — Abanico de 5 ondas, forma pared (cooldown 20s)
-- ============================================================
local function trapAttack(targetPos)
	if ai.isWaving or ai.isAttacking then return end
	ai.isWaving = true
	humanoid:MoveTo(hrp.Position)
	face(targetPos)
	stopMoveAnims()
	tracks.WAVE:Play(0.05)

	local fired = false
	local function doTrap()
		if fired then return end; fired = true
		sfx(CFG.SFX.TRAP_LAUNCH, 1.5, 0.5)
		local baseDir = (Vector3.new(targetPos.X, hrp.Position.Y, targetPos.Z) - hrp.Position)
		baseDir = baseDir.Magnitude > 0.1 and baseDir.Unit or hrp.CFrame.LookVector
		local halfSpread = CFG.TRAP_SPREAD / 2

		for i = 1, CFG.TRAP_COUNT do
			local t     = (i - 1) / math.max(CFG.TRAP_COUNT - 1, 1)
			local angle = math.rad(-halfSpread + t * CFG.TRAP_SPREAD)
			local dir   = CFrame.Angles(0, angle, 0) * baseDir

			task.delay((i - 1) * 0.07, function()
				local spawnCF = CFrame.lookAt(hrp.Position, hrp.Position + dir) * CFrame.new(0, 0, -3)
				spawnProjectile(spawnCF, dir, CFG.TRAP_SPEED, CFG.TRAP_SIZE, CFG.TRAP_DAMAGE, CFG.TRAP_LIFETIME)
			end)
		end
	end

	local conn = tracks.WAVE:GetMarkerReachedSignal("ONDADEATAQUE!"):Connect(doTrap)
	task.delay(0.6, doTrap)
	tracks.WAVE.Stopped:Wait()
	conn:Disconnect()
	ai.isWaving     = false
	ai.lastTrapTime = tick()
end

-- ============================================================
--  🗺️ NAVEGACION HIBRIDA
--  Prioridad: Directo > Steering (raycasts) > PathfindingService
-- ============================================================
local function cancelPath()
	if ai.pathThread then task.cancel(ai.pathThread); ai.pathThread = nil end
end

local navParams = RaycastParams.new()
navParams.FilterDescendantsInstances = {killer}
navParams.FilterType = Enum.RaycastFilterType.Exclude

-- NIVEL 1: Línea de visión directa al destino
local function hasDirectPath(dest)
	local origin = hrp.Position + Vector3.new(0, 1, 0)
	local dir    = (dest + Vector3.new(0, 1, 0)) - origin
	if dir.Magnitude < 0.1 then return true end
	local hit       = workspace:Raycast(origin, dir, navParams)
	local groundHit = workspace:Raycast(dest + Vector3.new(0, 3, 0), Vector3.new(0, -8, 0), navParams)
	return not hit and groundHit ~= nil
end

-- NIVEL 2: Steering con raycasts — esquiva sin PathfindingService
local function getSteerDir(dest)
	local toTarget  = (dest - hrp.Position)
	local flatDest  = Vector3.new(toTarget.X, 0, toTarget.Z).Unit
	local bestDir, bestScore = nil, -math.huge

	for a = 0, 7 do
		local angle   = (a / 8) * math.pi * 2
		local testDir = Vector3.new(math.cos(angle), 0, math.sin(angle))
		local hit     = workspace:Raycast(hrp.Position + Vector3.new(0,1,0), testDir * 5, navParams)
		local free    = not hit or hit.Distance > 3.5
		if free then
			local score = testDir:Dot(flatDest)
			if score > bestScore then bestScore = score; bestDir = testDir end
		end
	end
	return bestDir
end

-- ✅ Ground snap: encuentra el suelo real debajo de una posición
-- Evita que el path apunte al jugador flotando en el aire
local groundSnapParams = RaycastParams.new()
groundSnapParams.FilterDescendantsInstances = {killer}
groundSnapParams.FilterType = Enum.RaycastFilterType.Exclude

local function groundSnap(pos)
	-- Busca suelo hasta 40 studs abajo
	local hit = workspace:Raycast(pos + Vector3.new(0, 3, 0), Vector3.new(0, -40, 0), groundSnapParams)
	if hit then
		return Vector3.new(pos.X, hit.Position.Y + 0.5, pos.Z)
	end
	-- Si no hay suelo abajo, busca arriba (jugador debajo de una rampa)
	local hitUp = workspace:Raycast(pos - Vector3.new(0, 3, 0), Vector3.new(0, 40, 0), groundSnapParams)
	if hitUp then
		return Vector3.new(pos.X, hitUp.Position.Y + 0.5, pos.Z)
	end
	return pos
end

-- NIVEL 3: PathfindingService — solo laberintos complejos
local function followPath(dest)
	-- ✅ Snap al suelo antes de calcular — evita waypoints en el aire
	local snappedDest = groundSnap(dest)

	local path = PathfindingService:CreatePath(CFG.AGENT_PARAMS)
	local ok   = pcall(function() path:ComputeAsync(hrp.Position, snappedDest) end)
	if not ok or path.Status ~= Enum.PathStatus.Success then
		-- Intentar con la posición original si el snap falla
		ok = pcall(function() path:ComputeAsync(hrp.Position, dest) end)
		if not ok or path.Status ~= Enum.PathStatus.Success then
			local steerDir = getSteerDir(dest)
			humanoid:MoveTo(steerDir and hrp.Position + steerDir * 10 or dest)
			ai.pathThread = nil
			return
		end
	end

	local waypoints = path:GetWaypoints()
	for i = 2, #waypoints do
		if ai.isAttacking or ai.isWaving then ai.pathThread = nil; return end
		if ai.state == STATE.ATTACK or ai.state == STATE.WAVE or ai.state == STATE.TRAP then ai.pathThread = nil; return end

		local wp         = waypoints[i]
		local heightDiff = wp.Position.Y - hrp.Position.Y
		local onGround   = humanoid.FloorMaterial ~= Enum.Material.Air

		if (wp.Action == Enum.PathWaypointAction.Jump or heightDiff > 0.5) and onGround then
			humanoid.Jump = true
		end
		humanoid:MoveTo(wp.Position)
		face(wp.Position)

		local elapsed = 0
		while elapsed < CFG.WAYPOINT_TIMEOUT do
			task.wait(0.05); elapsed += 0.05
			if (wp.Position.Y - hrp.Position.Y) > 0.5 and humanoid.FloorMaterial ~= Enum.Material.Air then
				humanoid.Jump = true
			end
			if (hrp.Position - wp.Position).Magnitude < CFG.WAYPOINT_DIST then break end
			if hasDirectPath(dest) then ai.pathThread = nil; return end
		end
	end
	ai.pathThread = nil
end

-- Decide qué nivel de navegación usar para moverse al destino
local function navigateTo(dest, now)
	-- Cooldown: no recalcular si el destino no cambió suficiente
	local movedEnough = (dest - ai.lastPathComputePos).Magnitude > CFG.PATH_RECOMPUTE_DIST
	local timeExpired = (now - ai.lastPathComputeTime) > CFG.PATH_RECOMPUTE_TIME

	if not movedEnough and not timeExpired and ai.pathThread ~= nil then return end

	ai.lastPathComputePos  = dest
	ai.lastPathComputeTime = now

	-- NIVEL 1: Línea de visión directa
	if hasDirectPath(dest) then
		cancelPath()
		humanoid:MoveTo(dest)
		face(dest)
		return
	end

	-- NIVEL 2: Steering con raycasts — 16 direcciones para más precisión
	local toTarget  = (dest - hrp.Position)
	local flatDest  = Vector3.new(toTarget.X, 0, toTarget.Z)
	if flatDest.Magnitude > 0.1 then flatDest = flatDest.Unit end
	local bestDir, bestScore = nil, -math.huge

	for a = 0, 15 do
		local angle   = (a / 16) * math.pi * 2
		local testDir = Vector3.new(math.cos(angle), 0, math.sin(angle))
		local hit     = workspace:Raycast(hrp.Position + Vector3.new(0,1,0), testDir * 6, navParams)
		local free    = not hit or hit.Distance > 4
		if free then
			local score = testDir:Dot(flatDest)
			if score > bestScore then bestScore = score; bestDir = testDir end
		end
	end

	if bestDir then
		cancelPath()
		local steerDest = hrp.Position + bestDir * 14
		humanoid:MoveTo(steerDest)
		face(steerDest)
		return
	end

	-- NIVEL 3: PathfindingService
	cancelPath()
	ai.pathThread = task.spawn(followPath, dest)
end

-- ============================================================
--  🦯 ANTI-ATASCO
-- ============================================================
RunService.Heartbeat:Connect(function(dt)
	local moving = ai.state == STATE.CHASE or ai.state == STATE.EXPLORE
	if moving and not ai.isAttacking and not ai.isWaving then
		ai.stuckAccum += dt
		if ai.stuckAccum >= CFG.STUCK_CHECK_TIME then
			if (hrp.Position - ai.stuckPos).Magnitude < CFG.STUCK_MIN_DIST then
				humanoid.Jump = true
				local rp = RaycastParams.new()
				rp.FilterDescendantsInstances = {killer}
				rp.FilterType = Enum.RaycastFilterType.Exclude
				local bestAngle, bestDist = 0, -1
				for a = 0, 7 do
					local angle = (a / 8) * math.pi * 2
					local dir   = Vector3.new(math.cos(angle), 0, math.sin(angle))
					local hit   = workspace:Raycast(hrp.Position, dir * 10, rp)
					local d     = hit and hit.Distance or 10
					if d > bestDist then bestDist = d; bestAngle = angle end
				end
				humanoid:MoveTo(hrp.Position + Vector3.new(math.cos(bestAngle), 0, math.sin(bestAngle)) * 8)
				cancelPath(); ai.lastPathComputeTime = 0; ai.lastPathComputePos = Vector3.zero
				if ai.target then
					local tHRP = ai.target:FindFirstChild("HumanoidRootPart")
					if tHRP then
						ai.lastPathComputeTime = 0
						navigateTo(tHRP.Position, tick())
					end
				end
			end
			ai.stuckPos = hrp.Position; ai.stuckAccum = 0
		end
	else
		ai.stuckPos = hrp.Position; ai.stuckAccum = 0
	end
end)

-- ============================================================
--  👁️ HILO DE PERCEPCION (0.1s)
-- ============================================================
