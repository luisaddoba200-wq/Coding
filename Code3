local alignOri = hrp:FindFirstChild("_BeastAlignOri") or Instance.new("AlignOrientation", hrp)
alignOri.Name           = "_BeastAlignOri"
alignOri.Mode           = Enum.OrientationAlignmentMode.OneAttachment
alignOri.Attachment0    = rootAtt
alignOri.MaxTorque      = 1e4
alignOri.Responsiveness = 20

local _facingPos  = nil
local _currentYaw = hrp.CFrame.LookVector

RunService.Heartbeat:Connect(function(dt)
	if not _facingPos then return end
	local lookTarget = Vector3.new(_facingPos.X, hrp.Position.Y, _facingPos.Z)
	local toTarget   = lookTarget - hrp.Position
	if toTarget.Magnitude < 0.5 then return end

	local desired = toTarget.Unit
	local speed   = math.clamp(toTarget.Magnitude / 5, 4, 20)
	local alpha   = math.clamp(dt * speed, 0, 1)

	local nx = _currentYaw.X + (desired.X - _currentYaw.X) * alpha
	local nz = _currentYaw.Z + (desired.Z - _currentYaw.Z) * alpha
	local m  = math.sqrt(nx*nx + nz*nz)
	if m < 0.001 then return end
	_currentYaw = Vector3.new(nx/m, 0, nz/m)

	local dot = math.clamp(_currentYaw.X*desired.X + _currentYaw.Z*desired.Z, -1, 1)
	if dot < 0.9998 then
		alignOri.CFrame = CFrame.lookAt(hrp.Position, hrp.Position + _currentYaw)
	end
end)

local function face(pos) _facingPos = pos end

