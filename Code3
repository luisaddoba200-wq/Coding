local function activateRage()
	if ai.rageActive then ai.rageEndTime = tick() + CFG.RAGE_DURATION; return end
	ai.rageActive  = true
	ai.rageEndTime = tick() + CFG.RAGE_DURATION
	ai.rageHits    = 0

	for _, p in killer:GetDescendants() do
		if p:IsA("BasePart") and p.Name ~= "HumanoidRootPart" then
			local orig = p.Color
			TweenService:Create(p, TweenInfo.new(0.12), {Color = Color3.fromRGB(220,25,25)}):Play()
			task.delay(0.7, function()
				if p and p.Parent then TweenService:Create(p, TweenInfo.new(0.5), {Color=orig}):Play() end
			end)
		end
	end
	sfx(CFG.SFX.ROAR, 1.5, 0.38)
	tracks.ROAR:Play(0.05)
	print("[IntoTheChaos] 😠 RAGE MODE")
end

humanoid.HealthChanged:Connect(function()
	ai.rageHits += 1
	if ai.rageHits >= CFG.RAGE_HITS then activateRage() end
	ai.lastDamageTime = tick()
end)

