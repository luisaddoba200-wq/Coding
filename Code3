local function activateGhostMode()
	if ai.ghostModeActive then return end
	local now = tick()
	if now - ai.ghostModeLastUse < CFG.GHOST_MODE_COOLDOWN then return end

	ai.ghostModeActive   = true
	ai.ghostModeEndTime  = now + CFG.GHOST_MODE_DURATION
	ai.ghostModeLastUse  = now

	for _, part in ipairs(killer:GetDescendants()) do
		if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" then
			part.Transparency = CFG.GHOST_MODE_TRANSPARENCY
		end
	end

	sfx(CFG.SFX.GHOST, 1.0, 1.0)
	humanoid.WalkSpeed = humanoid.WalkSpeed * CFG.GHOST_MODE_SPEED_MULT
	print("[IntoTheChaos] 👻 Modo Fantasma activado")
end

local function deactivateGhostMode()
	if not ai.ghostModeActive then return end
	ai.ghostModeActive = false

	for _, part in ipairs(killer:GetDescendants()) do
		if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" then
			part.Transparency = 0
		end
	end

	humanoid.WalkSpeed = ai.rageActive and CFG.RAGE_SPEED or CFG.CHASE_SPEED
	print("IntoTheChaos] 👻 Modo Fantasma desactivado")
end

--============================================================
--  🗺️ NAVEGACIÓN MODERNA 2025
--  Usa PathfindingService con eventos (Path.Blocked, MoveToFinished)
--  en vez de loops. LOS directo cuando hay visión.
--============================================================

-- Estado de navegación
local NAV = {
	thread     = nil,   -- tarea activa de seguimiento de waypoints
	active     = false,
	dest       = Vector3.zero,
	startTime  = 0,
	liveRef    = nil,   -- referencia viva al HumanoidRootPart del target
}

-- Anclar al suelo real (fix rampas)
local function groundSnap(pos)
	local hit = workspace:Raycast(pos + Vector3.new(0,4,0), Vector3.new(0,-50,0), navParams)
	if hit then return Vector3.new(pos.X, hit.Position.Y + 0.5, pos.Z) end
	return pos
end

-- Posición actual del target (viva)
local function getLivePos()
	if NAV.liveRef and NAV.liveRef.Parent then return NAV.liveRef.Position end
	return NAV.dest
end

-- Cancelar navegación activa
local function cancelNav()
	NAV.active = false
	if NAV.thread then
		task.cancel(NAV.thread)
		NAV.thread = nil
	end
end

-- ── Función principal de navegación ─────────────────────────
-- Usa el método moderno: Path.Blocked event + MoveToFinished event
local function runPath(dest)
	NAV.active    = true
	NAV.dest      = dest
	NAV.startTime = tick()

	local snapped = groundSnap(dest)

	-- ── MODO LOS DIRECTO ────────────────────────────────────
	-- Si hay línea de visión, seguir al jugador con predicción
	if hasLOS(hrp.Position, snapped) then
		while NAV.active do
			task.wait(CFG.LOS_UPDATE_RATE)
			if not NAV.active then return end
			if ai.isAttacking or ai.isLunging then NAV.active = false; return end

			local cur = getLivePos()

			-- Llegamos
			if (hrp.Position - cur).Magnitude < CFG.WAYPOINT_DIST then
				NAV.active = false; return
			end
			-- Perdimos LOS → cambiar a pathfinding
			if not hasLOS(hrp.Position, cur) then
				NAV.active = false; return
			end

			-- ✅ PREDICCIÓN: apuntar a donde estará el jugador en PREDICT_FACTOR segundos
			-- Esto hace que el killer "adelante" al jugador en vez de seguirlo de atrás
			local liveRef = NAV.liveRef
			local predicted = cur
			if liveRef and liveRef.Parent then
				local vel     = liveRef.AssemblyLinearVelocity
				local flatVel = Vector3.new(vel.X, 0, vel.Z)
				if flatVel.Magnitude > 2 then
					predicted = cur + flatVel * CFG.PREDICT_FACTOR
					-- Solo usar predicción si el punto predicho también tiene LOS
					if not hasLOS(hrp.Position, predicted) then
						predicted = cur
					end
				end
			end

			face(predicted)
			humanoid:MoveTo(predicted)
			if cur.Y > hrp.Position.Y + 2.5 then humanoid.Jump = true end
		end
		NAV.active = false; return
	end

	-- ── MODO PATHFINDING (sin LOS) ───────────────────────────
	local path = PathfindingService:CreatePath(CFG.AGENT_PARAMS)

	-- Calcular path
	local ok = pcall(function() path:ComputeAsync(hrp.Position, snapped) end)
	if not ok or path.Status ~= Enum.PathStatus.Success then
		-- Fallback: intentar sin snap
		ok = pcall(function() path:ComputeAsync(hrp.Position, dest) end)
		if not ok or path.Status ~= Enum.PathStatus.Success then
			-- Último recurso: ir directo
			humanoid:MoveTo(dest)
			task.wait(2)
			NAV.active = false; return
		end
	end

	local wps = path:GetWaypoints()
	if #wps < 2 then
		humanoid:MoveTo(dest); task.wait(0.5); NAV.active = false; return
	end

	-- ── Evento Path.Blocked ──────────────────────────────────
	-- Si el path se bloquea, recomputar automáticamente
	local blockedConn = path.Blocked:Connect(function(blockedIdx)
		if blockedIdx > 1 then
			-- Recomputar desde posición actual
			breakObstacles()
			NAV.active = false  -- señal para salir del loop y recomputar
		end
	end)

	-- Variables de stuck detection
	local stuckTimer = 0
	local stuckRef   = hrp.Position

	local i = 2
	while i <= #wps and NAV.active do
		if ai.isAttacking or ai.isLunging then NAV.active = false; break end

		local livePos = getLivePos()

		-- Target se alejó mucho → recomputar
		if (livePos - dest).Magnitude > CFG.PATH_RECOMPUTE_DIST then
			NAV.active = false; break
		end

		-- Recuperamos LOS → cambiar a modo directo
		if hasLOS(hrp.Position, livePos) then
			while NAV.active do
				task.wait(CFG.LOS_UPDATE_RATE)
				local cp = getLivePos()
				if (hrp.Position - cp).Magnitude < CFG.WAYPOINT_DIST then
					NAV.active = false; break
				end
				if not hasLOS(hrp.Position, cp) then
					NAV.active = false; break
				end
				face(cp)
				humanoid:MoveTo(cp)
				if cp.Y > hrp.Position.Y + 2.5 then humanoid.Jump = true end
			end
			break
		end

		local wp = wps[i]

		-- ✅ WAYPOINT SKIP: si podemos ver el waypoint siguiente directamente,
		-- saltamos el actual para un path más fluido y rápido
		if i < #wps then
			local nextWp = wps[i + 1]
			if hasLOS(hrp.Position, nextWp.Position) then
				i += 1
				continue
			end
		end

		face(wp.Position)

		-- Saltar si el waypoint lo requiere o está más alto
		if wp.Action == Enum.PathWaypointAction.Jump
			or (wp.Position.Y - hrp.Position.Y) > 0.8 then
			if humanoid.FloorMaterial ~= Enum.Material.Air then
				humanoid.Jump = true
				task.wait(0.12)
			end
		end

		humanoid:MoveTo(wp.Position)

		-- ── Esperar MoveToFinished con timeout ───────────────
		local arrived = false
		local elapsed = 0

		local moveConn = humanoid.MoveToFinished:Connect(function(reached)
			arrived = true
		end)

		while not arrived and elapsed < CFG.WAYPOINT_TIMEOUT and NAV.active do
			task.wait(0.05)
			elapsed += 0.05

			-- Stuck detection mejorado
			stuckTimer += 0.05
			if stuckTimer >= CFG.STUCK_TIME then
				local moved = (hrp.Position - stuckRef).Magnitude
				if moved < CFG.STUCK_MIN_DIST then
					-- ✅ STUCK RECOVERY MEJORADO:
					-- 1. Saltar
					humanoid.Jump = true
					task.wait(0.1)
					-- 2. Retroceder brevemente para desatascarse
					local back = hrp.CFrame.LookVector * -4
					humanoid:MoveTo(hrp.Position + back)
					task.wait(0.15)
					-- 3. Romper obstáculos
					breakObstacles()
					moveConn:Disconnect()
					blockedConn:Disconnect()
					NAV.active = false
					return
				end
				stuckTimer = 0
				stuckRef   = hrp.Position
			end

			-- Si ya llegamos por distancia
			if (hrp.Position - wp.Position).Magnitude < CFG.WAYPOINT_DIST then
				arrived = true
			end
		end

		moveConn:Disconnect()

		if not arrived then
			-- Timeout → saltar e intentar continuar
			humanoid.Jump = true
			task.wait(0.1)
		end

		i += 1
	end

	blockedConn:Disconnect()
	NAV.active = false
end

-- ── navTo: cancela path anterior y lanza el nuevo ────────────
local function navTo(dest, liveRef)
	cancelNav()
	NAV.liveRef = liveRef
	NAV.dest    = dest
	NAV.thread  = task.spawn(runPath, dest)
end

-- ── Decidir si recomputar ─────────────────────────────────────
local function navNeedsRecompute(newDest)
	if not NAV.active then return true end
	if (newDest - NAV.dest).Magnitude > CFG.PATH_RECOMPUTE_DIST then return true end
	if tick() - NAV.startTime > CFG.PATH_RECOMPUTE_TIME then return true end
	return false
end

-- ── Actualizar nav en chase ───────────────────────────────────
local function chaseNavUpdate(targetHRP)
	NAV.liveRef = targetHRP  -- siempre actualizar referencia viva
	local dest  = targetHRP.Position
	if navNeedsRecompute(dest) then
		navTo(dest, targetHRP)
	end
end

--============================================================
--  🗺️ EXPLORACIÓN
--============================================================
local function isPointSafe(pos)
	-- Verificar que hay suelo debajo
	local hit = workspace:Raycast(pos + Vector3.new(0,2,0), Vector3.new(0,-15,0), navParams)
	if not hit then return false end  -- vacío debajo

	-- Verificar que no está en el borde de una caída
	-- Comprueba los 4 lados a 2 studs de distancia
	local offsets = {
		Vector3.new(2,0,0), Vector3.new(-2,0,0),
		Vector3.new(0,0,2), Vector3.new(0,0,-2),
	}
	local edgeCount = 0
	for _, offset in ipairs(offsets) do
		local sidePos = pos + offset
		local sideHit = workspace:Raycast(sidePos + Vector3.new(0,2,0), Vector3.new(0,-15,0), navParams)
		if not sideHit then
			edgeCount += 1
		end
	end
	-- Si 3+ lados tienen vacío, es una esquina peligrosa
	return edgeCount < 3
end

local function registerVisited(pos)
	ai.visitedZoneIdx = (ai.visitedZoneIdx % CFG.EXPLORE_ZONE_MEMORY) + 1
	ai.visitedZones[ai.visitedZoneIdx] = pos
end

local function isTooNearVisited(pos)
	for _, vz in ipairs(ai.visitedZones) do
		if (pos - vz).Magnitude < CFG.EXPLORE_ZONE_REUSE then return true end
	end
	return false
end

local function newExplorePoint()
	local now = tick()
	if now - ai.exploreExpandedAt > CFG.EXPLORE_EXPAND_TIME then
		ai.exploreRadius      = math.min(ai.exploreRadius + 15, CFG.EXPLORE_RADIUS_MAX)
		ai.exploreExpandedAt  = now
	end
	for attempt = 1, 20 do
		local baseAngle   = (attempt / 20) * math.pi * 2
		local randOffset  = (math.random() - 0.5) * math.pi * 0.6
		local angle       = baseAngle + randOffset
		local r           = CFG.EXPLORE_RADIUS_MIN + math.random() * (ai.exploreRadius - CFG.EXPLORE_RADIUS_MIN)
		local candidate   = hrp.Position + Vector3.new(math.cos(angle)*r, 0, math.sin(angle)*r)
		if not isTooNearVisited(candidate) and isPointSafe(candidate) then
			return candidate
		end
	end
	ai.visitedZones   = {}
	ai.visitedZoneIdx = 0
	ai.exploreRadius  = CFG.EXPLORE_RADIUS_MIN
	return hrp.Position + Vector3.new(0, 0, 10)
end

--============================================================
--  🤖 HILO PRINCIPAL
--============================================================
task.spawn(function()
	playAnim("WALK", 0.1)

	while task.wait(0.1) do
		local now   = tick()
		local speed = ai.rageActive and CFG.RAGE_SPEED or CFG.CHASE_SPEED

		-- Rage timeout
		if ai.rageActive and now > ai.rageEndTime then
			ai.rageActive = false
		end

		-- Ghost mode timeout
		if ai.ghostModeActive and now > ai.ghostModeEndTime then
			deactivateGhostMode()
		end

		-- Actualizar target
		local nearest = getNearestPlayer()
		ai.target = nearest or nil
		if nearest then
			ai.lastKnownPos = nearest.HumanoidRootPart.Position
		end

		-- Sin jugador → explorar
		if not ai.target then
			if ai.state ~= STATE.EXPLORE then
				cancelNav()
				ai.state = STATE.EXPLORE
			end
		else
			local tHRP = ai.target.HumanoidRootPart
			local dist = (tHRP.Position - hrp.Position).Magnitude
			face(tHRP.Position)
			local dest = tHRP.Position

			-- Ghost mode activo
			if ai.ghostModeActive then
				ai.state = STATE.GHOST
				humanoid.WalkSpeed = CFG.CHASE_SPEED * CFG.GHOST_MODE_SPEED_MULT
				chaseNavUpdate(tHRP)

			elseif dist <= CFG.ATTACK_RANGE then
				ai.state = STATE.ATTACK
				cancelNav()

			elseif dist >= CFG.LUNGE_RANGE_MIN and dist <= CFG.LUNGE_RANGE_MAX
				and now - ai.lastLungeTime > CFG.COOLDOWN_LUNGE
				and not ai.isAttacking then
				if math.random() < (ai.rageActive and CFG.RAGE_LUNGE_PROB or 0.25) then
					ai.state = STATE.LUNGE
					cancelNav()
				else
					ai.state = STATE.CHASE
				end
			else
				ai.state = STATE.CHASE
			end

			-- Chase logic
			if ai.state == STATE.CHASE then
				humanoid.WalkSpeed = speed

				-- Flanqueo
				if CFG.FLANK_ENABLED and not ai.isFlanking and dist > 25
					and math.random() < CFG.FLANK_PROB and now - ai.lastFlankTime > 8 then
					local vel     = tHRP.AssemblyLinearVelocity
					local flatVel = Vector3.new(vel.X, 0, vel.Z)
					if flatVel.Magnitude > 0.5 then
						local perp    = Vector3.new(-flatVel.Z, 0, flatVel.X).Unit
						local side    = math.random(0,1) == 0 and 1 or -1
						local flankDest = tHRP.Position + flatVel.Unit*10 + perp*CFG.FLANK_OFFSET*side
						local groundHit = workspace:Raycast(flankDest + Vector3.new(0,5,0), Vector3.new(0,-20,0), navParams)
						if groundHit then
							-- ✅ FIX: navegar al destino de flankeo, no al target directo
							navTo(flankDest, tHRP)
							ai.isFlanking    = true
							ai.lastFlankTime = now
							task.delay(5, function() ai.isFlanking = false end)
						end
					end
				end

				-- Solo actualizar nav normal si no estamos flanqueando
				if not ai.isFlanking then
					chaseNavUpdate(tHRP)
				end

				-- Trigger ghost mode si lleva mucho tiempo persiguiendo
				if not ai.ghostModeActive then
					if ai.chaseStartTime == 0 then
						ai.chaseStartTime = now
					elseif now - ai.chaseStartTime > CFG.GHOST_MODE_TRIGGER_TIME then
						activateGhostMode()
						ai.chaseStartTime = 0
					end
				else
					ai.chaseStartTime = 0
				end
			end
		end

		-- ── Estados específicos ──────────────────────────────
		if ai.state == STATE.EXPLORE then
			humanoid.WalkSpeed = CFG.PATROL_SPEED
			if not ai.exploreTarget
				or (hrp.Position - ai.exploreTarget).Magnitude < 8 then
				if now >= ai.exploreWaitUntil then
					registerVisited(hrp.Position)
					ai.exploreTarget    = newExplorePoint()
					ai.exploreWaitUntil = now + math.random() * (CFG.EXPLORE_WAIT_MAX - CFG.EXPLORE_WAIT_MIN) + CFG.EXPLORE_WAIT_MIN
					navTo(ai.exploreTarget, nil)
					face(ai.exploreTarget)
				else
					humanoid:MoveTo(hrp.Position)
				end
			else
				face(ai.exploreTarget)
			end

		elseif ai.state == STATE.ATTACK then
			if not ai.target then
				ai.state = STATE.EXPLORE
			else
				local tHRP = ai.target.HumanoidRootPart
				local dist = (tHRP.Position - hrp.Position).Magnitude
				if not ai.isAttacking then
					if dist <= CFG.HEAVY_RANGE and now - ai.lastHeavyTime > CFG.COOLDOWN_HEAVY
						and math.random() < (ai.rageActive and 0.55 or 0.38) then
						task.spawn(heavyAttack)
					elseif now - ai.lastLightTime > CFG.COOLDOWN_LIGHT then
						task.spawn(lightAttack)
					end
				end
				if dist > CFG.ATTACK_RANGE * 0.8 then
					humanoid:MoveTo(tHRP.Position)
				else
					humanoid:MoveTo(hrp.Position)
				end
			end

		elseif ai.state == STATE.LUNGE then
			if ai.target and not ai.isLunging then
				task.spawn(function()
					performLunge(ai.target.HumanoidRootPart)
				end)
			else
				ai.state = STATE.CHASE
			end
		end
	end
end)

