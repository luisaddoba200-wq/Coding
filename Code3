local navParams = RaycastParams.new()
navParams.FilterDescendantsInstances = {killer}
navParams.FilterType = Enum.RaycastFilterType.Exclude

local function hasLOS(fromPos, toPos)
	local origin = fromPos + Vector3.new(0, 1.5, 0)
	local dir    = (toPos + Vector3.new(0, 1, 0)) - origin
	local result = workspace:Raycast(origin, dir, navParams)
	return not result or result.Distance >= dir.Magnitude * 0.92
end

local function getNearestPlayer()
	local nearest, minDist = nil, math.huge
	for _, p in Players:GetPlayers() do
		local char = p.Character
		if char and char:FindFirstChild("Humanoid") and char.Humanoid.Health > 0
			and char:FindFirstChild("HumanoidRootPart") then
			local dist = (char.HumanoidRootPart.Position - hrp.Position).Magnitude
			if dist < minDist then
				minDist = dist
				nearest = char
			end
		end
	end
	return nearest, minDist
end

