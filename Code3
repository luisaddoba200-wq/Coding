local function lightAttack()
	if ai.isAttacking then return end
	ai.isAttacking = true

	local now = tick()
	ai.comboCount    = (now - ai.lastComboTime < CFG.COMBO_WINDOW) and math.min(ai.comboCount+1, CFG.MAX_COMBO) or 1
	ai.lastComboTime = now

	humanoid:MoveTo(hrp.Position)
	stopMoveAnims()
	tracks.ATTACK:Play(0.05)

	local fired = false
	local function doHit()
		if fired then return end; fired = true
		local dmg = CFG.DAMAGE_LIGHT * (1 + (ai.comboCount-1) * CFG.COMBO_DMG_MULT)
		areaHit(dmg, 6.5, 4)
		sfx(CFG.SFX.HIT, 0.8, 0.88 + ai.comboCount * 0.07)
	end

	local conn = tracks.ATTACK:GetMarkerReachedSignal("IntoTheChaosAttack!"):Connect(doHit)
	task.delay(0.45, doHit)

	local startTime = tick()
	task.spawn(function()
		while ai.isAttacking and tick()-startTime < 3 do task.wait(0.1) end
		conn:Disconnect()
		if tracks.ATTACK.IsPlaying then tracks.ATTACK:Stop(0.1) end
		ai.isAttacking = false; ai.lastLightTime = tick()
	end)

	tracks.ATTACK.Stopped:Wait()
	conn:Disconnect()
	ai.isAttacking = false; ai.lastLightTime = tick()
end

local function heavyAttack()
	if ai.isAttacking then return end
	ai.isAttacking = true

	humanoid:MoveTo(hrp.Position)
	stopMoveAnims()
	tracks.HEAVY:Play(0.05)

	local fired = false
	local function doHit()
		if fired then return end; fired = true
		areaHit(CFG.DAMAGE_HEAVY, 10, 5)
		sfx(CFG.SFX.HIT, 1.5, 0.52)
	end

	local conn = tracks.HEAVY:GetMarkerReachedSignal("IntoTheChaosAttack!"):Connect(doHit)
	task.delay(0.45, doHit)

	local startTime = tick()
	task.spawn(function()
		while ai.isAttacking and tick()-startTime < 4 do task.wait(0.1) end
		conn:Disconnect()
		if tracks.HEAVY.IsPlaying then tracks.HEAVY:Stop(0.1) end
		ai.isAttacking = false; ai.lastHeavyTime = tick(); ai.lastLightTime = tick()
	end)

	tracks.HEAVY.Stopped:Wait()
	conn:Disconnect()
	ai.isAttacking = false; ai.lastHeavyTime = tick(); ai.lastLightTime = tick()
end

local function performLunge(tHRP)
	if ai.isLunging or ai.isAttacking then return end
	ai.isLunging = true; ai.isAttacking = true

	stopMoveAnims()
	tracks.LUNGE:Play(0.05)
	face(tHRP.Position)
	task.wait(CFG.LUNGE_WINDUP)
	sfx(CFG.SFX.ROAR, 1.2, 0.62)

	local dir    = (tHRP.Position - hrp.Position + Vector3.new(0, 0.25, 0)).Unit
	local att    = Instance.new("Attachment", hrp)
	local lv     = Instance.new("LinearVelocity", hrp)
	lv.Attachment0    = att
	lv.VectorVelocity = dir * CFG.LUNGE_FORCE
	lv.MaxForce       = 9e5
	humanoid.WalkSpeed = 0

	local elapsed = 0; local hitsLeft = CFG.LUNGE_HIT_MAX_HITS; local hitTable = {}
	while elapsed < CFG.LUNGE_HIT_MAX_TIME and hitsLeft > 0 do
		task.wait(CFG.LUNGE_HIT_TICK); elapsed += CFG.LUNGE_HIT_TICK
		local p2 = OverlapParams.new()
		p2.FilterDescendantsInstances = {killer}; p2.FilterType = Enum.RaycastFilterType.Exclude
		for _, part in workspace:GetPartBoundsInRadius(hrp.Position, CFG.LUNGE_HIT_RADIUS, p2) do
			local model = part:FindFirstAncestorOfClass("Model")
			if model and model ~= killer and not hitTable[model] then
				local hum  = model:FindFirstChildOfClass("Humanoid")
				local mHRP = model:FindFirstChild("HumanoidRootPart")
				if hum and hum.Health > 0 then
					hitTable[model] = true; hitsLeft -= 1
					local mult = ai.rageActive and CFG.RAGE_DMG_MULT or 1
					hum:TakeDamage(math.floor(CFG.DAMAGE_LUNGE * mult))
					sfx(CFG.SFX.HIT, 1.2, 0.65)
					if mHRP then applyKnockback(mHRP, dir + Vector3.new(0,0.6,0), CFG.KNOCKBACK_FORCE*1.8) end
					if hitsLeft <= 0 then break end
				end
			end
		end
	end

	lv:Destroy(); att:Destroy()
	local startTime = tick()
	task.spawn(function()
		while ai.isLunging and tick()-startTime < 3 do task.wait(0.1) end
		if tracks.LUNGE.IsPlaying then tracks.LUNGE:Stop(0.1) end
		humanoid.WalkSpeed = ai.rageActive and CFG.RAGE_SPEED or CFG.CHASE_SPEED
		ai.isLunging = false; ai.isAttacking = false
		ai.lastLungeTime = tick(); ai.lastLightTime = tick()
	end)

	task.wait(0.15)
	tracks.LUNGE.Stopped:Wait()
	humanoid.WalkSpeed = ai.rageActive and CFG.RAGE_SPEED or CFG.CHASE_SPEED
	ai.isLunging = false; ai.isAttacking = false
	ai.lastLungeTime = tick(); ai.lastLightTime = tick()
end

